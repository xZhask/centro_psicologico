# ── Base de datos ────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=centro_psicologico
DB_USER=root
DB_PASS=

# ── Aplicación ───────────────────────────────────────────────────
APP_ENV=production          # production | development
APP_DEBUG=false             # true solo en desarrollo local
APP_LOG_PATH=../logs/php_errors.log

# ── Sesiones ─────────────────────────────────────────────────────
SESSION_LIFETIME=7200       # segundos (2 horas)

# ── Correo (SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_USER=tu_correo@ejemplo.com
SMTP_PASS=tu_contraseña
SMTP_FROM_EMAIL=no-reply@centro.com
SMTP_FROM_NAME="Centro Psicológico"

# ── Twilio (WhatsApp) ─────────────────────────────────────────────
TWILIO_SID=tu_twilio_sid
TWILIO_TOKEN=tu_twilio_token
TWILIO_WHATSAPP_FROM=+14155238886
