# ── Base de datos ────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=centro_psicologico
DB_USER=root
DB_PASS=

# ── Aplicación ───────────────────────────────────────────────────
APP_ENV=production          # production | development
APP_DEBUG=false             # true solo en desarrollo local
APP_LOG_PATH=../logs/php_errors.log

# ── Sesiones ─────────────────────────────────────────────────────
SESSION_LIFETIME=7200       # segundos (2 horas)
